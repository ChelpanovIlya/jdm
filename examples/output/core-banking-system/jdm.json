      { "version": "1.0.0", "date": "2026-05-06", "changes": ["Initial design: CLIENT, ADDRESS, BANK_ACCOUNT, CURRENCY"] },
      { "version": "1.1.0", "date": "2026-05-06", "changes": ["Added 'balance_national' Decimal attribute to BANK_ACCOUNT for reporting"] }
    ]
  }
}
